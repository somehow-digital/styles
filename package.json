{
	"name": "@somehow-digital/styles",
	"type": "module",
	"version": "1.0.0",
	"packageManager": "pnpm@10.33.0",
	"description": "Shared `CSS` styles for `somehow.digital` projects.",
	"license": "MIT",
	"repository": "somehow-digital/styles",
	"exports": {
		".": "./src/index.js",
		"./css": "./dist/styles.css"
	},
	"files": [
		"./dist/",
		"./src/"
	],
	"engines": {
		"node": ">=22",
		"pnpm": ">=10"
	},
	"scripts": {
		"prepack": "pnpm build",
		"prepare": "husky",
		"build": "node ./scripts/build.js",
		"lint": "concurrently --group --prefix-colors 'auto' 'pnpm:lint:*'",
		"lint:eslint": "eslint .",
		"lint:cspell": "cspell --no-progress --no-summary --no-must-find-files .",
		"lint:knip": "knip --no-progress",
		"fix": "concurrently --group --prefix-colors 'auto' 'pnpm:fix:*'",
		"fix:eslint": "eslint --fix .",
		"fix:knip": "knip --fix --no-progress --workspace ."
	},
	"devDependencies": {
		"@commitlint/cli": "^20.0.0",
		"@somehow-digital/commitlint-config": "^1.0.0",
		"@somehow-digital/cspell-dictionary": "^2.0.0",
		"@somehow-digital/eslint-config": "^5.0.0",
		"@somehow-digital/semantic-release-config": "^2.0.0",
		"concurrently": "^9.0.0",
		"cspell": "^10.0.0",
		"eslint": "^10.0.0",
		"husky": "^9.0.11",
		"knip": "^6.0.0",
		"lint-staged": "^16.0.0",
		"semantic-release": "^25.0.0"
	}
}
